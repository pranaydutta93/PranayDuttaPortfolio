                },
                {
                    "src": "proscenium/Work Images/7.jpg",
                    "title": "Proscenium VII",
                    "medium": "Graphite and charcoal on paper",
                    "size": "18in x 24in",
                    "year": "2025"
                }
            ],
            "description": [
                "This work examines landscapes as constructed images rather than neutral realities. It looks at how facades are used to shape perception by concealing what lies beneath. The idea of the Potemkin village serves as a key reference, showing how architecture and surface visuals create convincing illusions. These staged landscapes often mimic nature and evoke familiarity, yet remain artificial. When emptied of people, the illusion weakens. Through drawing, the work reveals seams, scaffolding, and structure, exposing how selective framing constructs belief while hiding other realities."
            ],
            "installation_images": [
                {
                    "src": "proscenium/Installation Images/1.jpg",
                    "label": "Alien Shores: landscape, once removed, White Cube, Bermondsey, 2025"
                }
            ]
        }
    },
